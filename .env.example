# Copy this file to .env.local. Never put real keys in this committed example.
#
# Legacy shared fallback only. Prefer the two explicit Agent channels below.
NEWAPI_BASE_URL=

# Image Agent: character sheets and incremental actions via images/edits;
# owner-confirmed new backgrounds use the same API root via images/generations.
# Recommended model: GPT Image 2.
NEWAPI_IMAGE_BASE_URL=https://image-provider.example.com/v1/images/edits
NEWAPI_IMAGE_API_KEY=
NEWAPI_IMAGE_MODEL=gpt-image-2

# Text Agents: character decisions/dialogue, Director, story compaction, and
# optional character-research assistance. Recommended: DeepSeek V4 family.
# Use your provider's exact model ID; this project defaults to v4-flash.
NEWAPI_TEXT_BASE_URL=https://text-provider.example.com/v1
NEWAPI_TEXT_API_KEY=
NEWAPI_TEXT_MODEL=deepseek-v4-flash
