# Legacy shared fallback only. Prefer the two explicit Agent channels below.
NEWAPI_BASE_URL=

# Image Agent: character sheets and incremental actions via images/edits;
# owner-confirmed new backgrounds use the same API root via images/generations.
NEWAPI_IMAGE_BASE_URL=https://image-provider.example.com/v1/images/edits
NEWAPI_IMAGE_API_KEY=
NEWAPI_IMAGE_MODEL=gpt-image-2

# Text Agents: Character Agent decisions and responses.
NEWAPI_TEXT_BASE_URL=https://text-provider.example.com
NEWAPI_TEXT_API_KEY=
NEWAPI_TEXT_MODEL=deepseek-v4-flash
